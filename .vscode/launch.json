{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend (ts-node direct)",
      "cwd": "${workspaceFolder}/BackEnd",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-r", "ts-node/register", "src/index.ts"],
      "env": { "NODE_ENV": "development" },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
