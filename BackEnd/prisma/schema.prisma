generator client {
  provider = "prisma-client"
  url     =  env("DATABASE_URL")
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  first_name      String?
  last_name      String?
  user_name     String   @unique 
  password  String
  createdAt DateTime @default(now())
  lastUpdatedAt DateTime @updatedAt
}

model Invoice {
  id           String   @id @default(uuid())
  document_type String?
  invoice_date DateTime?
  mark  String?
  series  String?
  number  String?
  issuer_vat_number String?
  issuer_name String?
  recipient_vat_number String?
  recipient_name String?
  recipient_code String?
  project        String?
  payment_method String?
  value_before_discount Decimal?  @db.Decimal(10, 2)
  discount_amount Decimal?  @db.Decimal(10, 2)
  net_amount Decimal?  @db.Decimal(10, 2)
  vat_amount Decimal?  @db.Decimal(10, 2)
  withholding_amount Decimal? @db.Decimal(10, 2)
  fees_or_stamps String?
  total_amount   Decimal?  @db.Decimal(10, 2)
  issuer_iban           String?
  is_paid         Boolean?
  comments       String? 
  company        String?
  category       String?
  expense_type   String?
  file_url       String?
  file_hash      String?
  file_upload_id String?
  createdBy      String?
  createdAt      DateTime @default(now())
  lastUpdatedAt  DateTime @updatedAt
}