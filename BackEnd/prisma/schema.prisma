generator client {
  provider = "prisma-client"
  url     =  env("DATABASE_URL")
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  first_name      String?
  last_name      String?
  user_name     String   @unique 
  phone         String?
  is_approver   Boolean  @default(false)
  approver_number String?
  password  String
  createdAt DateTime @default(now())
  lastUpdatedAt DateTime @updatedAt
}

model Invoice {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_type String?
  invoice_date DateTime? @db.Date
  mark  String? @unique
  series  String?
  number  String?
  issuer_vat_number String?
  issuer_name String?
  recipient_vat_number String?
  recipient_name String?
  recipient_code String?
  project        String?
  payment_method String?
  value_before_discount Decimal?  @db.Decimal(10, 2)
  discount_amount Decimal?  @db.Decimal(10, 2)
  net_amount Decimal?  @db.Decimal(10, 2)
  vat_amount Decimal?  @db.Decimal(10, 2)
  withholding_amount Decimal? @db.Decimal(10, 2)
  fees_or_stamps String?
  total_amount   Decimal?  @db.Decimal(10, 2)
  issuer_iban           String?
  is_paid         Boolean?
  comments       String? 
  company        String?
  category       String?
  expense_type   String?
  file_url       String?
  file_path      String?
  display_name   String?
  file_hash      String?
  file_upload_id String?
  status         String @default("complete")
  approval_status String?
  approver_id    String?
  createdBy      String?
  createdAt      DateTime @default(now())
  lastUpdatedAt  DateTime @updatedAt
}

model CompanyVatRegistry {
  vat_number   String   @id
  company_name String
  source       String?  @default("auto")
  created_at   DateTime? @default(now())
  updated_at   DateTime? @default(now())
}
